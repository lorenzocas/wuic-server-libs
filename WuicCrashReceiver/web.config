<?xml version="1.0" encoding="utf-8"?>
<!--
  WuicCrashReceiver — IIS hosting (skill crash-reporting Commit 11).
  Deployato in `C:\inetpub\wwwroot\errors.wuic-framework.com\` su Windows
  Server 2025. Usa AspNetCoreModuleV2 (out-of-process portable in-process
  con `hostingModel="inprocess"` che è il default più performante).

  Le path verso `dotnet.exe` e `.\WuicCrashReceiver.dll` sono RELATIVE alla
  directory dove stiamo eseguendo (publish output) — IIS ANCM le risolve
  rispetto a physicalPath del sito.

  ipSecurity (commentato): da abilitare in produzione con i tuoi IP
  ammessi. Si applica solo a `/api/admin/*` via location below; il resto
  (ingest, consent) deve restare pubblico (auth via license headers).
-->
<configuration>
  <location path="." inheritInChildApplications="false">
    <system.webServer>
      <handlers>
        <add name="aspNetCore" path="*" verb="*" modules="AspNetCoreModuleV2" resourceType="Unspecified" />
      </handlers>
      <aspNetCore processPath="dotnet"
                  arguments=".\WuicCrashReceiver.dll"
                  stdoutLogEnabled="true"
                  stdoutLogFile="C:\inetpub\WuicCrashReceiver\logs\stdout"
                  hostingModel="inprocess">
        <environmentVariables>
          <environmentVariable name="ASPNETCORE_ENVIRONMENT" value="Production" />
          <!-- Override puntuali si fanno qui o via appsettings.Production.json -->
        </environmentVariables>
      </aspNetCore>
      <httpProtocol>
        <customHeaders>
          <!-- Sicurezza base: il receiver non e' un'app interattiva, ma il
               browser carica /admin/ static SPA → conviene comunque proteggerla. -->
          <add name="X-Content-Type-Options" value="nosniff" />
          <add name="X-Frame-Options" value="DENY" />
          <add name="Referrer-Policy" value="no-referrer" />
        </customHeaders>
      </httpProtocol>
    </system.webServer>
  </location>

  <!--
    Skill crash-reporting Commit 14: IP whitelist per /api/admin/* (decisione 12).
    NOTA tecnica: ho originariamente provato a mettere ipSecurity in
    <location path="api/admin"> ma quel block override il <handlers>
    parent → IIS non passa piu' le request a ASP.NET Core → 404 da IIS.
    Soluzione: NON usare ipSecurity a livello IIS edge. La protezione e'
    invece gestita dal middleware applicativo `AdminAuth` (vedi
    Services/AdminAuth.cs) che fa la stessa IP whitelist + bearer fallback,
    leggendo la lista da Admin:AllowedIp in appsettings.Production.json.

    Trade-off accettato: perdiamo 1 layer di defense-in-depth (filtro
    edge IIS prima ancora di toccare l'app), guadagniamo endpoint
    funzionanti + auditability migliore (le request rejected vanno a log
    strutturato dell'app invece di sparire nel 403 IIS).
  -->
</configuration>
