{
  "folders": [
    {
      "path": "KonvergenceCore"
    },
    {
      "path": "RuntimeEfCore"
    },
    {
      "path": "Wuic.Webcore"
    },
    {
      "path": "WuicOData"
    },
    {
      "path": "postgresql"
    },
    {
      "path": "oracle"
    },
    {
      "path": "mysql"
    },
    {
      "path": "CrmApp"
    },
    {
      "path": "codebase_docs"
    },
    {
      "path": "codebase_embeddings"
    },
    {
      "path": "WuicTest"
    }
  ],
  "settings": {
    "search.exclude": {
      "**/lib-src/**": true,
      "**/codebase_docs/md_chunks/**": true,
      "**/codebase_embeddings/**": true
    },
    "files.watcherExclude": {
      "**/node_modules/**": true,
      "**/dist/**": true,
      "**/.angular/**": true,
      "**/bin/**": true,
      "**/obj/**": true,
      "**/codebase_docs/md_chunks/**": true,
      "**/codebase_embeddings/**": true,
      "**/.venv/**": true,
      "**/App_Data/**": true
    },
    "CodeGPT.apiKey": "Claude Code",
    "powershell.cwd": "KonvergenceCore",
    "sarif-viewer.connectToGithubCodeScanning": "off",
    "semgrep.scan.configuration": [
      "p/csharp",
      "p/typescript"
    ],
    "semgrep.scan.onlyGitDirty": false,
    "semgrep.scan.secrets": false,
    "chatgpt.openOnStartup": true,
    "chat.imageCarousel.enabled": true,
    "typescript.tsdk": "WuicTest/wwwroot/node_modules/typescript/lib",
    "typescript.enablePromptUseWorkspaceTsdk": true,
    "js/ts.tsdk.path": "WuicTest/wwwroot/node_modules/typescript/lib",
    "typescript.tsserver.maxTsServerMemory": 2048,
    "python.languageServer": "None",
    "python.analysis.indexing": false,
    "python.analysis.diagnosticMode": "openFilesOnly"
  }
}