        <Name>cities</Name>
        <NameInSource>Connessione</NameInSource>
        <Parameters isList="true" count="0" />
        <SqlCommand>SELECT [Application].[Cities].[CityID] AS [CityID], [Application].[Cities].[CityName] AS [CityName],  [StateProvinceID_stateprovinces].[StateProvinceCode] AS [stateprovinces___StateProvinceCode__StateProvinceID], [Application].[Cities].[StateProvinceID] AS [StateProvinceID], concat('{"lat":',CONVERT(varchar(20), cast([Application].[Cities].[Location]  AS geography).Lat),',"lng":',CONVERT(varchar(20), cast([Application].[Cities].[Location]  AS geography).Long),'}') AS [Location], [Application].[Cities].[LatestRecordedPopulation] AS [LatestRecordedPopulation],  [LastEditedBy_people].[FullName] AS [people___FullName__LastEditedBy], [Application].[Cities].[LastEditedBy] AS [LastEditedBy], [Application].[Cities].[ValidFrom] AS [ValidFrom], [Application].[Cities].[ValidTo] AS [ValidTo] FROM [Application].[Cities]   LEFT JOIN [Application].[StateProvinces] AS [StateProvinceID_stateprovinces] ON [Application].[Cities].[StateProvinceID] = [StateProvinceID_stateprovinces].[StateProvinceID]   LEFT JOIN [Application].[People] AS [LastEditedBy_people] ON [Application].[Cities].[LastEditedBy] = [LastEditedBy_people].[PersonID]     ORDER BY [Application].[Cities].CityID ASC </SqlCommand>
      </cities>
