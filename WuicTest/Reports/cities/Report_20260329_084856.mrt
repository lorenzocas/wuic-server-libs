        <Dictionary isRef="1" />
        <Key>e54a85f8f9494c2fb8d2291a6790fa59</Key>
        <Name>schedules</Name>
        <NameInSource>Connessione</NameInSource>
        <Parameters isList="true" count="0" />
        <SqlCommand>SELECT [Sales].[Schedules].[ScheduleId] AS [ScheduleId],  [CityId_cities].[CityName] AS [cities___CityName__CityId], [Sales].[Schedules].[CityId] AS [CityId],  [PersonId_people].[FullName] AS [people___FullName__PersonId], [Sales].[Schedules].[PersonId] AS [PersonId], [Sales].[Schedules].[FromDate] AS [FromDate], [Sales].[Schedules].[ToDate] AS [ToDate], [Sales].[Schedules].[Note] AS [Note], [Sales].[Schedules].[Recurring] AS [Recurring] FROM [Sales].[Schedules]   LEFT JOIN [WideWorldImporters].[Application].[Cities] AS [CityId_cities] ON [Sales].[Schedules].[CityId] = [CityId_cities].[CityID]   LEFT JOIN [Application].[People] AS [PersonId_people] ON [Sales].[Schedules].[PersonId] = [PersonId_people].[PersonID]     ORDER BY [Sales].[Schedules].ScheduleId ASC </SqlCommand>
      </schedules>
