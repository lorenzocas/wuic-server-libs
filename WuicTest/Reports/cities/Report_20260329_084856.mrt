        <Key>196c158da94b436b8a4ece504b086a17</Key>
        <Name>cities</Name>
        <NameInSource>Connessione</NameInSource>
        <Parameters isList="true" count="0" />
        <SqlCommand>SELECT [WideWorldImporters].[Application].[Cities].[CityID] AS [CityID],  ''  AS [asas], [WideWorldImporters].[Application].[Cities].[CityName] AS [CityName],  [StateProvinceID_stateprovinces].[StateProvinceCode] AS [stateprovinces___StateProvinceCode__StateProvinceID], [WideWorldImporters].[Application].[Cities].[StateProvinceID] AS [StateProvinceID], concat('{"lat":',CONVERT(varchar(20), cast([WideWorldImporters].[Application].[Cities].[Location]  AS geography).Lat),',"lng":',CONVERT(varchar(20), cast([WideWorldImporters].[Application].[Cities].[Location]  AS geography).Long),'}') AS [Location], [WideWorldImporters].[Application].[Cities].[LatestRecordedPopulation] AS [LatestRecordedPopulation],  [LastEditedBy_people].[FullName] AS [people___FullName__LastEditedBy], [WideWorldImporters].[Application].[Cities].[LastEditedBy] AS [LastEditedBy], [WideWorldImporters].[Application].[Cities].[ValidFrom] AS [ValidFrom], [WideWorldImporters].[Application].[Cities].[ValidTo] AS [ValidTo], [WideWorldImporters].[Application].[Cities].[deleted] AS [deleted] FROM [WideWorldImporters].[Application].[Cities]   LEFT JOIN [Application].[StateProvinces] AS [StateProvinceID_stateprovinces] ON [WideWorldImporters].[Application].[Cities].[StateProvinceID] = [StateProvinceID_stateprovinces].[StateProvinceID]   LEFT JOIN [Application].[People] AS [LastEditedBy_people] ON [WideWorldImporters].[Application].[Cities].[LastEditedBy] = [LastEditedBy_people].[PersonID]     where  coalesce([WideWorldImporters].[Application].[Cities].[deleted],0) = 0 ORDER BY [WideWorldImporters].[Application].[Cities].CityID ASC </SqlCommand>
      </cities>
