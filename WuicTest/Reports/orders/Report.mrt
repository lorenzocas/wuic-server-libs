        <Parameters isList="true" count="0" />
        <SqlCommand>SELECT [Sales].[Orders].[OrderID] AS [OrderID],  [CustomerID_customers].[CustomerName] AS [customers___CustomerName__CustomerID], [Sales].[Orders].[CustomerID] AS [CustomerID],  [SalespersonPersonID_people].[FullName] AS [people___FullName__SalespersonPersonID], [Sales].[Orders].[SalespersonPersonID] AS [SalespersonPersonID],  [PickedByPersonID_people].[FullName] AS [people___FullName__PickedByPersonID], [Sales].[Orders].[PickedByPersonID] AS [PickedByPersonID],  [ContactPersonID_people].[FullName] AS [people___FullName__ContactPersonID], [Sales].[Orders].[ContactPersonID] AS [ContactPersonID],  [BackorderOrderID_orders].[CustomerPurchaseOrderNumber] AS [orders___CustomerPurchaseOrderNumber__BackorderOrderID], [Sales].[Orders].[BackorderOrderID] AS [BackorderOrderID], [Sales].[Orders].[OrderDate] AS [OrderDate], [Sales].[Orders].[ExpectedDeliveryDate] AS [ExpectedDeliveryDate], [Sales].[Orders].[CustomerPurchaseOrderNumber] AS [CustomerPurchaseOrderNumber], [Sales].[Orders].[IsUndersupplyBackordered] AS [IsUndersupplyBackordered], [Sales].[Orders].[Comments] AS [Comments], [Sales].[Orders].[DeliveryInstructions] AS [DeliveryInstructions], [Sales].[Orders].[InternalComments] AS [InternalComments], [Sales].[Orders].[PickingCompletedWhen] AS [PickingCompletedWhen],  [LastEditedBy_people].[FullName] AS [people___FullName__LastEditedBy], [Sales].[Orders].[LastEditedBy] AS [LastEditedBy], [Sales].[Orders].[LastEditedWhen] AS [LastEditedWhen] FROM [Sales].[Orders] LEFT JOIN [Sales].[Customers] AS [CustomerID_customers] ON [Sales].[Orders].[CustomerID] = [CustomerID_customers].[CustomerID] 
LEFT JOIN [Application].[People] AS [SalespersonPersonID_people] ON [Sales].[Orders].[SalespersonPersonID] = [SalespersonPersonID_people].[PersonID]   
LEFT JOIN [Application].[People] AS [PickedByPersonID_people] ON [Sales].[Orders].[PickedByPersonID] = [PickedByPersonID_people].[PersonID] 
LEFT JOIN [Application].[People] AS [ContactPersonID_people] ON [Sales].[Orders].[ContactPersonID] = [ContactPersonID_people].[PersonID] 
LEFT JOIN [Sales].[Orders] AS [BackorderOrderID_orders] ON [Sales].[Orders].[BackorderOrderID] = [BackorderOrderID_orders].[OrderID]   
LEFT JOIN [Application].[People] AS [LastEditedBy_people] ON [Sales].[Orders].[LastEditedBy] = [LastEditedBy_people].[PersonID]   ORDER BY [Sales].[Orders].OrderID ASC </SqlCommand>
      </orders>
