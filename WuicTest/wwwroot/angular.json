{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "newProjectRoot": "projects",
  "projects": {
    "wuic-test": {
      "projectType": "application",
      "root": "",
      "sourceRoot": "src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "loader": {
              ".ttf": "binary"
            },
            "outputPath": "dist/wuic-test",
            "index": "src/index.html",
            "browser": "src/main.ts",
            "polyfills": [
              "zone.js"
            ],
            "tsConfig": "tsconfig.app.json",
            "inlineStyleLanguage": "scss",
            "assets": [
              {
                "glob": "**/*",
                "input": "public"
              },
              {
                "glob": "**/*",
                "input": "assets",
                "output": "assets"
              },
              {
                "glob": "**/*",
                "input": "../../node_modules/monaco-editor/min/vs",
                "output": "assets/monaco-editor/min/vs"
              }
            ],
            "styles": [
              "../../node_modules/bootstrap/dist/css/bootstrap-grid.min.css",
              "../../node_modules/primeicons/primeicons.css",
              "../../node_modules/primeflex/primeflex.css",
              "assets/styles.scss",
              "../../node_modules/jsuites/dist/jsuites.css",
              "../../node_modules/jspreadsheet/dist/jspreadsheet.css"
            ],
            "scripts": [],
            "stylePreprocessorOptions": {
              "includePaths": [
                "../../KonvergenceCore/wwwroot/my-workspace/projects/wuic-framework-lib/assets",
                "node_modules/wuic-framework-lib"
              ]
            },
            "preserveSymlinks": true
          },
          "configurations": {
            "production": {
              "optimization": false,
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "10MB",
                  "maximumError": "100MB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "10MB",
                  "maximumError": "100MB"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              "optimization": true,
              "extractLicenses": false,
              "sourceMap": {
                "scripts": true,
                "styles": true,
                "vendor": true
              }
            },
            "npm": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": {
                "scripts": true,
                "styles": true,
                "vendor": true
              },
              "fileReplacements": [
                { "replace": "src/app/wuic-bridges/core.ts", "with": "src/app/wuic-bridges-npm/core.ts" },
                { "replace": "src/app/wuic-bridges/ui.ts", "with": "src/app/wuic-bridges-npm/ui.ts" },
                { "replace": "src/app/wuic-bridges/notifications.ts", "with": "src/app/wuic-bridges-npm/notifications.ts" },
                { "replace": "src/app/wuic-bridges/routes.ts", "with": "src/app/wuic-bridges-npm/routes.ts" },
                { "replace": "src/app/wuic-bridges/widget-loaders.ts", "with": "src/app/wuic-bridges-npm/widget-loaders.ts" },
                { "replace": "src/app/wuic-bridges/widget-loaders-advanced.ts", "with": "src/app/wuic-bridges-npm/widget-loaders-advanced.ts" }
              ]
            }
          },
          "defaultConfiguration": "development"
        },
        "serve": {
          "builder": "@angular-devkit/build-angular:dev-server",
          "configurations": {
            "production": {
              "buildTarget": "wuic-test:build:production"
            },
            "development": {
              "buildTarget": "wuic-test:build:development"
            },
            "npm": {
              "buildTarget": "wuic-test:build:npm"
            }
          },
          "defaultConfiguration": "development"
        },
        "test": {
          "builder": "@angular/build:unit-test",
          "options": {
            "tsConfig": "tsconfig.spec.json",
            "exclude": ["src/app/environments/**"]
          }
        }
      }
    }
  }
}
