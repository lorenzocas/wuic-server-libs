{
  "name": "wuic-test-standalone",
  "version": "0.0.1",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "serve:dev": "ng serve wuic-test --configuration=development --prebundle=true --host localhost --port 4200",
    "serve:npm": "ng serve wuic-test --configuration=npm --host localhost --port 4200",
    "build:dev": "ng build wuic-test --configuration=development",
    "//build:prod": "DEV-TIME ONLY. The 'production' angular.json config has NO fileReplacement for environment.ts -> environment.prod.ts, so the bundle keeps absolute http://localhost:5000 URLs. DO NOT ship this output. For releasable bundles use 'build:npm' (consumed by deploy-release.ps1).",
    "build:prod": "ng build wuic-test --configuration=production",
    "//build:npm": "Canonical release build. Used by deploy-release.ps1. Has fileReplacements for environment.ts->environment.prod.ts (path-relative URLs, work behind any reverse proxy) and wuic-bridges/* -> wuic-bridges-npm/*.",
    "build:npm": "ng build wuic-test --configuration=npm",
    "test:selectors:ngdeep": "node e2e/check-ngdeep-selectors.mjs",
    "test:selectors:ngdeep:strict": "node e2e/check-ngdeep-selectors.mjs --strict"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^21.2.1",
    "@angular/cdk": "^21.2.1",
    "@angular/common": "^21.2.1",
    "@angular/compiler": "^21.2.1",
    "@angular/core": "^21.2.1",
    "@angular/elements": "^21.2.1",
    "@angular/forms": "^21.2.1",
    "@angular/google-maps": "^21.2.1",
    "@angular/platform-browser": "^21.2.1",
    "@angular/platform-browser-dynamic": "^21.2.1",
    "@angular/router": "^21.2.1",
    "@fullcalendar/angular": "^6.1.16",
    "@fullcalendar/bootstrap5": "^6.1.15",
    "@fullcalendar/core": "^6.1.15",
    "@fullcalendar/daygrid": "^6.1.15",
    "@fullcalendar/interaction": "^6.1.15",
    "@fullcalendar/timegrid": "^6.1.15",
    "@googlemaps/markerclusterer": "^2.5.3",
    "@materia-ui/ngx-monaco-editor": "^6.0.0",
    "@ngx-translate/core": "^15.0.0",
    "@primeuix/themes": "^2.0.3",
    "bootstrap": "^5.3.3",
    "chart.js": "^4.4.6",
    "dexie": "^4.0.8",
    "monaco-editor": "^0.45.0",
    "monaco-editor-webpack-plugin": "^7.1.0",
    "ngx-cookie-service": "^21.0.0",
    "primeflex": "^3.3.1",
    "primeicons": "^7.0.0",
    "primeng": "^21.1.3",
    "quill": "^2.0.3",
    "rete": "^2.0.1",
    "rete-angular-plugin": "^2.6.0",
    "rete-area-plugin": "^2.0.0",
    "rete-connection-plugin": "^2.0.0",
    "rete-render-utils": "^2.0.0",
    "rxjs": "~7.8.0",
    "stimulsoft-designer-angular": "^2026.1.7",
    "stimulsoft-reports-js": "^2026.1.7",
    "stimulsoft-viewer-angular": "^2026.1.7",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^21.2.1",
    "@angular/build": "^21.2.1",
    "@angular/cli": "^21.2.1",
    "@angular/compiler-cli": "^21.2.1",
    "jsdom": "^29.0.1",
    "ng-packagr": "^21.2.1",
    "playwright": "^1.59.1",
    "typescript": "~5.9.3",
    "vitest": "^4.1.0"
  }
}
