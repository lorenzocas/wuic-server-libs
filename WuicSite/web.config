<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.webServer>
    <!-- Hide IIS Server header (security audit 2026-05-02 · L-02). -->
    <security>
      <requestFiltering removeServerHeader="true" />
    </security>

    <!--
      Security response headers (audit 2026-05-02 · H-03, M-03, L-02).
      `script-src 'unsafe-inline'` is required because Angular's prerender
      bootstrap injects inline `<script type="module">` and inline state
      blocks. To tighten further, switch the build to nonce-based CSP and
      remove `'unsafe-inline'`. PayPal SDK + REST endpoints are explicitly
      whitelisted in script-src/connect-src/frame-src.
    -->
    <httpProtocol>
      <customHeaders>
        <remove name="X-Powered-By" />
        <add name="Strict-Transport-Security" value="max-age=63072000; includeSubDomains; preload" />
        <add name="X-Content-Type-Options" value="nosniff" />
        <add name="X-Frame-Options" value="DENY" />
        <add name="Referrer-Policy" value="strict-origin-when-cross-origin" />
        <add name="Permissions-Policy" value="camera=(), microphone=(), geolocation=(), payment=(self &quot;https://www.paypal.com&quot;)" />
        <add name="Cross-Origin-Opener-Policy" value="same-origin" />
        <add name="Cross-Origin-Resource-Policy" value="same-site" />
        <add name="Content-Security-Policy" value="default-src 'self'; script-src 'self' https://www.paypal.com https://www.sandbox.paypal.com 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self' data:; connect-src 'self' https://www.paypal.com https://api.paypal.com; frame-src https://www.paypal.com https://www.sandbox.paypal.com; object-src 'none'; base-uri 'self'; form-action 'self' https://www.paypal.com" />
      </customHeaders>
    </httpProtocol>

    <!--
      Register .md as a real text MIME type so IIS serves the markdown
      sources of the engineering blog (under /assets/blog/) directly
      instead of falling through to the SPA rewrite below — which would
      hand back the home page's HTML and break the BlogPost renderer.
      Without this entry IIS returns 404 for .md files (extension not in
      the default MIME database), the rewrite catches the 404, and the
      browser's `fetch('/assets/blog/foo.md')` happily resolves with
      `Content-Type: text/html` + the home page body. `marked.parse`
      then injects the home page inside the article. We've been there.
    -->
    <staticContent>
      <remove fileExtension=".md" />
      <mimeMap fileExtension=".md" mimeType="text/markdown; charset=UTF-8" />
    </staticContent>
    <rewrite>
      <rules>
        <!--
          Force HTTPS (audit 2026-05-02 · H-01). MUST be the first rule:
          every plaintext request gets a 301 to its HTTPS counterpart
          before any other matching kicks in. Combined with the HSTS
          header above (max-age=2y, preload), browsers stop hitting :80
          after the first visit. Pre-requisite: HTTPS binding is healthy
          on every host this config serves (wuic-framework.com + any
          subdomain that reuses this config).
        -->
        <rule name="ForceHttps" stopProcessing="true">
          <match url=".*" />
          <conditions>
            <add input="{HTTPS}" pattern="off" ignoreCase="true" />
          </conditions>
          <action type="Redirect" url="https://{HTTP_HOST}/{R:0}" redirectType="Permanent" />
        </rule>

        <!--
          Deny dot-paths (audit 2026-05-02 · L-07). Without this, the
          Angular SPA fallback below answers HTTP 200 (with the home page
          HTML) for /.git/HEAD, /.env, /.vs/, /.svn/ — confusing scanners
          and masking accidental real leaks if a dot-path ever happens to
          match an Angular route. Returning 404 explicitly removes the
          ambiguity.
        -->
        <rule name="DenyDotPaths" stopProcessing="true">
          <match url="(^|/)\.(git|env|vs|svn)(/|$)" />
          <action type="CustomResponse" statusCode="404" statusReason="Not Found" statusDescription="Not Found" />
        </rule>

        <!--
          Skip /api/* paths so they reach the WuicSiteApi sub-application
          (configured in IIS as a child app under wuic-framework.com/api,
          backed by AspNetCoreModuleV2 + a server-managed appsettings.json
          with the PayPal Client SECRET — see WuicSite/api/Program.cs).
        -->
        <rule name="API passthrough" stopProcessing="true">
          <match url="^api(/.*)?$" />
          <action type="None" />
        </rule>

        <!--
          Prerendered static HTML for SSG routes. After enabling Angular's
          `outputMode: "static"` the build emits one folder per route with
          its own index.html (e.g. /comparison/index.html, /features/index.html,
          /docs/index.html) — these contain the SEO-relevant payload (title,
          per-page meta robots, canonical, JSON-LD). Without this rule IIS
          would skip them and fall straight through to the SPA fallback,
          serving the home page's HTML for every URL — Google would then
          see only one indexable page.

          Match: any non-empty URL whose corresponding `<segment>/index.html`
          exists on disk. We re-check `IsFile` first so request to actual
          files (favicon.ico, /assets/og-image.svg, /downloads/file.zip,
          /flags/4x3/it.svg) bypass this rule and are served as-is.

          Why the dot-condition `(.+?)/?$`:
            - captures the path without trailing slash so /comparison and
              /comparison/ both rewrite to the same physical file.
            - `+?` (non-greedy) avoids over-eating the path on routes with
              dashes or slashes like /downloads/older.
        -->
        <rule name="Prerendered HTML" stopProcessing="true">
          <match url="^(.+?)/?$" />
          <conditions logicalGrouping="MatchAll">
            <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="true" />
            <add input="{DOCUMENT_ROOT}\{R:1}\index.html" matchType="IsFile" />
          </conditions>
          <action type="Rewrite" url="/{R:1}/index.html" />
        </rule>

        <!--
          Angular SPA fallback: anything that is NOT a real file on disk
          and does NOT have a matching prerendered HTML gets rewritten to
          the root /index.html so the Angular Router can handle it (e.g.
          /docs/some-slug, /blog/article-slug — both client-rendered).

          Why we DON'T also exclude `IsDirectory`:
            The site has physical folders that share their name with SPA
            routes — most importantly /downloads/ (where the deploy script
            uploads the WuicTest ZIP releases). With an `IsDirectory` check
            in place, a request to /downloads/ would fall through the
            rewrite (because the folder exists), then IIS would try to
            list the directory; with directory browsing disabled (the IIS
            default), the response is HTTP 403 — which is what Lighthouse,
            Googlebot, and copy/pasted URLs all hit.

            By only checking `IsFile`, real files inside those folders
            (e.g. /downloads/WuicTest-...zip, /assets/og-image.svg) keep
            being served as static assets, while bare folder URLs fall
            through to the SPA which has its own /downloads route component.
        -->
        <rule name="Angular SPA Fallback" stopProcessing="true">
          <match url=".*" />
          <conditions logicalGrouping="MatchAll">
            <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="true" />
          </conditions>
          <action type="Rewrite" url="/index.html" />
        </rule>
      </rules>
    </rewrite>
  </system.webServer>
</configuration>
