<?xml version="1.0" encoding="utf-8"?>
<!--
  Source-checked-in web.config for the WuicSiteApi sub-app. `dotnet publish`
  uses this as a template and only patches <aspNetCore processPath/arguments>
  with the build-output values; everything else (handlers, hosting model)
  survives across publishes verbatim. Security headers are NOT here — they
  live in the C# middleware (see comment inside the <location> block).
-->
<configuration>
  <location path="." inheritInChildApplications="false">
    <system.webServer>
      <handlers>
        <add name="aspNetCore" path="*" verb="*" modules="AspNetCoreModuleV2" resourceType="Unspecified" />
      </handlers>
      <aspNetCore processPath="dotnet" arguments=".\WuicSiteApi.dll" stdoutLogEnabled="true" stdoutLogFile=".\logs\stdout" hostingModel="inprocess" />

      <!--
        Security headers (audit 2026-05-02 · H-03, M-03) are emitted by an
        ASP.NET Core middleware in Program.cs (`UseSecurityHeaders`) instead
        of <httpProtocol> here. Reason: the production IIS applicationHost.config
        locks BOTH <security> and <httpProtocol> sections at parent scope, so
        any header config inside this <location inheritInChildApplications="false">
        triggers an IIS-level "lock violation" that returns HTTP 500 for every
        /api/* request before the .NET worker is even loaded (observed twice
        post-deploy 2026-05-02). Doing it from C# middleware sidesteps the
        whole lock-policy mess and makes the headers config-managed in one
        place.
      -->
    </system.webServer>
  </location>
</configuration>
