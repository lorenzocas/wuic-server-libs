<?xml version="1.0" encoding="utf-8"?>
<!--
  Project-local NuGet config: overrides any user-level / machine-wide feeds
  (e.g. private Azure DevOps feeds that require Bearer auth) and uses only
  the public nuget.org. WuicSiteApi has no internal/private dependencies.
-->
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>
  <packageSourceMapping>
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
  </packageSourceMapping>
</configuration>
