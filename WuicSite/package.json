{
  "name": "wuic-site",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "serve:dev": "ng serve",
    "sitemap": "node scripts/generate-sitemap.mjs",
    "sitemap:check": "node scripts/check-sitemap.mjs",
    "blog:manifest": "node scripts/generate-blog-manifest.mjs",
    "prebuild": "node scripts/generate-sitemap.mjs && node scripts/generate-blog-manifest.mjs",
    "build": "ng build",
    "postbuild": "node scripts/check-sitemap.mjs",
    "watch": "ng build --watch --configuration development",
    "test": "ng test"
  },
  "private": true,
  "packageManager": "npm@11.9.0",
  "dependencies": {
    "@angular/cdk": "^21.2.6",
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@ngx-translate/core": "^17.0.0",
    "@ngx-translate/http-loader": "^17.0.0",
    "@primeng/themes": "^21.0.4",
    "flag-icons": "^7.5.0",
    "highlight.js": "^11.11.1",
    "marked": "^18.0.3",
    "primeicons": "^7.0.0",
    "primeng": "^21.1.5",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.7",
    "@angular/cli": "^21.2.7",
    "@angular/compiler-cli": "^21.2.0",
    "@angular/platform-server": "^21.2.11",
    "@angular/ssr": "^21.2.9",
    "@types/node": "^25.6.0",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2"
  }
