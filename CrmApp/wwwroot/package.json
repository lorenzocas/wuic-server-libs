{
  "name": "my-workspace",
  "version": "0.0.1",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "test:unit:wuic-lib": "ng test wuic-framework-lib --watch=false --browsers=ChromeHeadless",
    "test:e2e:wuic": "node scripts/run-wuic-playwright-if-enabled.mjs",
    "test:e2e:wuic:force": "playwright test -c playwright.wuic.config.ts",
    "test:e2e:wuic:integration": "playwright test -c playwright.wuic.config.ts playwright/wuic-integration.spec.ts",
    "test:e2e:wuic:menu-routes": "playwright test -c playwright.wuic.config.ts playwright/wuic-menu-routes.spec.ts",
    "test:e2e:wuic:menu-stress": "playwright test -c playwright.wuic.config.ts playwright/wuic-menu-stress.spec.ts",
    "test:e2e:wuic:list": "playwright test -c playwright.wuic.config.ts --list",
    "test:stress:server": "node scripts/run-wuic-k6-stress.mjs",
    "test:stress:server:quick": "node scripts/run-wuic-k6-stress.mjs -e WUIC_K6_DURATION=30s -e WUIC_K6_VUS=8",
    "test:stress:server:matrix": "powershell -ExecutionPolicy Bypass -File scripts/run-wuic-k6-matrix.ps1",
    "serve:dev": "ng serve crm-app --configuration=development --prebundle=false --host localhost --port 4200",
    "serve:npm": "ng serve crm-app --configuration=npm --host localhost --port 4200",
    "build:lib:npm": "ng build wuic-framework-lib -c production",
    "build:lib": "ng build wuic-framework-lib --watch",
    "publish:lib": "ng build wuic-framework-lib -c production && cd dist/wuic-framework-lib && npm publish --access public --registry https://registry.npmjs.org/ && cd ../..",
    "test:unit:crm-app": "ng test crm-app --watch=false --browsers=ChromeHeadless"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^21.2.1",
    "@angular/cdk": "^21.2.1",
    "@angular/common": "^21.2.1",
    "@angular/compiler": "^21.2.1",
    "@angular/core": "^21.2.1",
    "@angular/elements": "^21.2.1",
    "@angular/forms": "^21.2.1",
    "@angular/google-maps": "^21.2.1",
    "@angular/platform-browser": "^21.2.1",
    "@angular/platform-browser-dynamic": "^21.2.1",
    "@angular/router": "^21.2.1",
    "@fullcalendar/angular": "^6.1.16",
    "@fullcalendar/bootstrap5": "^6.1.15",
    "@fullcalendar/core": "^6.1.15",
    "@fullcalendar/daygrid": "^6.1.15",
    "@fullcalendar/interaction": "^6.1.15",
    "@fullcalendar/timegrid": "^6.1.15",
    "@googlemaps/markerclusterer": "^2.5.3",
    "@materia-ui/ngx-monaco-editor": "^6.0.0",
    "@ngx-translate/core": "^15.0.0",
    "@primeng/themes": "^21.0.4",
    "bootstrap": "^5.3.3",
    "chart.js": "^4.4.6",
    "dexie": "^4.0.8",
    "jspreadsheet": "^11.9.3",
    "monaco-editor": "^0.45.0",
    "monaco-editor-webpack-plugin": "^7.1.0",
    "ngx-cookie-service": "^19.0.0",
    "primeflex": "^3.3.1",
    "primeicons": "^7.0.0",
    "primeng": "^21.1.3",
    "quill": "^2.0.3",
    "rete": "^2.0.1",
    "rete-angular-plugin": "^2.6.0",
    "rete-area-plugin": "^2.0.0",
    "rete-connection-plugin": "^2.0.0",
    "rete-render-utils": "^2.0.0",
    "rxjs": "~7.8.0",
    "stimulsoft-designer-angular": "^2024.4.3",
    "stimulsoft-reports-js": "^2026.1.4",
    "stimulsoft-viewer-angular": "^2024.4.3",
    "tslib": "^2.3.0",
    "wuic-framework-lib": "file:../../KonvergenceCore/wwwroot/my-workspace/dist/wuic-framework-lib",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^21.2.1",
    "@angular/cli": "^21.2.1",
    "@angular/compiler-cli": "^21.2.1",
    "@playwright/test": "^1.58.2",
    "@types/jasmine": "~5.1.0",
    "@xmldom/xmldom": "^0.9.8",
    "jasmine-core": "~5.2.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "ng-packagr": "^21.2.0",
    "playwright": "^1.58.2",
    "typescript": "~5.9.3"
  }
}
