        <Parameters isList="true" count="0" />
        <SqlCommand>SELECT [AdvancedCRM].[dbo].[crm_opportunities].[opportunity_id] AS [opportunity_id],  [account_id_crm_accounts].[account_name] AS [crm_accounts___account_name__account_id], [AdvancedCRM].[dbo].[crm_opportunities].[account_id] AS [account_id],  [contact_id_crm_contacts].[first_name] AS [crm_contacts___first_name__contact_id], [AdvancedCRM].[dbo].[crm_opportunities].[contact_id] AS [contact_id], [AdvancedCRM].[dbo].[crm_opportunities].[title] AS [title], [AdvancedCRM].[dbo].[crm_opportunities].[amount] AS [amount], [AdvancedCRM].[dbo].[crm_opportunities].[expected_close_date] AS [expected_close_date],  [stage_id_crm_opportunity_stage].[stage_code] AS [crm_opportunity_stage___stage_code__stage_id], [AdvancedCRM].[dbo].[crm_opportunities].[stage_id] AS [stage_id],  [owner_user_id_crm_users].[username] AS [crm_users___username__owner_user_id], [AdvancedCRM].[dbo].[crm_opportunities].[owner_user_id] AS [owner_user_id],  [lead_id_crm_leads].[source] AS [crm_leads___source__lead_id], [AdvancedCRM].[dbo].[crm_opportunities].[lead_id] AS [lead_id], [AdvancedCRM].[dbo].[crm_opportunities].[Stato_Record] AS [Stato_Record], [AdvancedCRM].[dbo].[crm_opportunities].[created_at] AS [created_at], [AdvancedCRM].[dbo].[crm_opportunities].[updated_at] AS [updated_at],  ''  AS [btn_crm_opportunities_duplicate] FROM [AdvancedCRM].[dbo].[crm_opportunities]   LEFT JOIN [AdvancedCRM].[dbo].[crm_accounts] AS [account_id_crm_accounts] ON [AdvancedCRM].[dbo].[crm_opportunities].[account_id] = [account_id_crm_accounts].[account_id]   LEFT JOIN [AdvancedCRM].[dbo].[crm_contacts] AS [contact_id_crm_contacts] ON [AdvancedCRM].[dbo].[crm_opportunities].[contact_id] = [contact_id_crm_contacts].[contact_id]   LEFT JOIN [AdvancedCRM].[dbo].[crm_opportunity_stage] AS [stage_id_crm_opportunity_stage] ON [AdvancedCRM].[dbo].[crm_opportunities].[stage_id] = [stage_id_crm_opportunity_stage].[stage_id]   LEFT JOIN [AdvancedCRM].[dbo].[crm_users] AS [owner_user_id_crm_users] ON [AdvancedCRM].[dbo].[crm_opportunities].[owner_user_id] = [owner_user_id_crm_users].[user_id]   LEFT JOIN [AdvancedCRM].[dbo].[crm_leads] AS [lead_id_crm_leads] ON [AdvancedCRM].[dbo].[crm_opportunities].[lead_id] = [lead_id_crm_leads].[lead_id]     ORDER BY [AdvancedCRM].[dbo].[crm_opportunities].opportunity_id ASC </SqlCommand>
      </crm_opportunities>
